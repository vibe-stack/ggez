{
  "name": "ggez-gaming",
  "private": true,
  "license": "MIT",
  "packageManager": "bun@1.3.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "samples/*"
  ],
  "scripts": {
    "dev": "bun run --cwd apps/editor dev",
    "dev:all": "bun run --filter '@ggez/editor' --filter '@ggez/three-runtime-playground' --filter '@ggez/three-vanilla-playground' dev",
    "start": "bun run --cwd apps/orchestrator dev",
    "changeset": "changeset",
    "build": "bun run --cwd apps/editor build",
    "build:orchestrator": "bun run --cwd apps/orchestrator build",
    "typecheck": "bun run --cwd apps/editor typecheck",
    "typecheck:orchestrator": "bun run --cwd apps/orchestrator typecheck",
    "dev:website": "bun run --cwd apps/website dev",
    "build:website": "bun run --cwd apps/website build",
    "typecheck:website": "bun run --cwd apps/website typecheck",
    "dev:animation-editor": "bun run --cwd apps/animation-editor dev",
    "build:animation-editor": "bun run --cwd apps/animation-editor build",
    "typecheck:animation-editor": "tsc -p apps/animation-editor/tsconfig.json --noEmit",
    "build:packages": "bun ./scripts/release-packages.mjs build",
    "version:packages": "changeset version",
    "publish:packages:dry-run": "bun ./scripts/release-packages.mjs publish --dry-run",
    "publish:packages": "bun ./scripts/release-packages.mjs publish",
    "dev:three-runtime": "bun run --cwd apps/three-runtime-playground dev",
    "build:three-runtime": "bun run --cwd apps/three-runtime-playground build",
    "typecheck:three-runtime": "bun run --cwd apps/three-runtime-playground typecheck",
    "dev:three-vanilla": "bun run --cwd apps/three-vanilla-playground dev",
    "build:three-vanilla": "bun run --cwd apps/three-vanilla-playground build",
    "typecheck:three-vanilla": "bun run --cwd apps/three-vanilla-playground typecheck"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/node": "^24.10.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "^0.19.2",
    "three-mesh-bvh": "^0.9.2"
  }
}
