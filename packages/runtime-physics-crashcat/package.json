  "devDependencies": {
    "@types/three": "^0.181.0"
  },
  "dependencies": {
    "@ggez/render-pipeline": "workspace:*",
    "@ggez/runtime-format": "workspace:*",
    "@ggez/shared": "workspace:*",
    "crashcat": "^0.0.3",
    "three": "^0.181.1"
